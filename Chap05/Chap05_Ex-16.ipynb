   "metadata": {},
   "source": [
    "cos関数の範囲(0, np.pi)の積分を求めてみましょう"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "12c925b1",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "from scipy import integrate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "17c1c043",
   "metadata": {},
   "outputs": [],
   "source": [
    "def f(x):\n",
    "    return np.cos(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b0bc614d",
   "metadata": {},
   "outputs": [],
   "source": [
    "integrate.quad(f, 0, np.pi)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5aeebacf",
   "metadata": {},
   "outputs": [],
   "source": []
  }
