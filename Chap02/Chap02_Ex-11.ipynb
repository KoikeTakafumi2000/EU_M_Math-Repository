   "source": [
    "y=sin(x)とy=cos(x)のグラフを重ねて描いてください（ は-10から10の値）。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "52b8a0f1",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "f3e3f431",
   "metadata": {},
   "outputs": [],
   "source": [
    "x = np.linspace(-10, 10, 100)\n",
    "y1 = np.sin(x)\n",
    "y2 = np.cos(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "1a990361",
   "metadata": {},
   "outputs": [
    {
     "data": {
