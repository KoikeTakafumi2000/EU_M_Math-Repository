 "cells": [
  {
   "cell_type": "markdown",
   "id": "4ae71f62",
   "metadata": {},
   "source": [
    "要素がすべて3の5行5列の行列を作成し、その行列の2乗をする計算をしてみましょう。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "4c8775fd",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "7e71f9b5",
   "metadata": {},
   "outputs": [],
   "source": [
    "Matrix = np.ones((5, 5)) * 3"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "31106fb1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]]\n"
     ]
    }
   ],
   "source": [
    "print(Matrix @ Matrix)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "b67babd5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]\n",
      " [45. 45. 45. 45. 45.]]\n"
     ]
    }
   ],
   "source": [
    "print(np.dot(Matrix, Matrix))"
   ]
  },
